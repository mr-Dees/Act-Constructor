{
  "name": "audit-workstation",
  "version": "0.1.0",
  "private": true,
  "description": "Audit Workstation — vanilla JS frontend (Native ES Modules, без bundler'а) + Playwright E2E",
  "scripts": {
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "test:js": "node --test tests/js/*.test.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "fast-check": "^4.8.0"
  }
}
