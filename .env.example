# ============================================================
# Audit Workstation — Environment Configuration
# ============================================================
# Скопируйте этот файл как .env и заполните значения.
# Переменные используют __ как разделитель вложенных настроек.
# ============================================================

# Метаданные приложения
APP_TITLE=Audit Workstation
APP_VERSION=1.0.0

# Аутентификация (JupyterHub / DataLab)
# В DataLab берётся из переменных окружения автоматически.
JUPYTERHUB_USER=00000000_omega-sbrf-ru

# === Сервер ===
SERVER__HOST=0.0.0.0
SERVER__PORT=8000
SERVER__API_V1_PREFIX=/api/v1
SERVER__LOG_LEVEL=INFO

# === База данных ===
# Тип: "postgresql" (локальная) или "greenplum" (через Kerberos)
DATABASE__TYPE=postgresql
DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__NAME=audit_workstation
DATABASE__USER=postgres
DATABASE__PASSWORD=
DATABASE__POOL_MIN_SIZE=2
DATABASE__POOL_MAX_SIZE=10
DATABASE__COMMAND_TIMEOUT=60

# === Greenplum (только при DATABASE__TYPE=greenplum) ===
# Требует предварительный kinit для Kerberos-аутентификации.
DATABASE__GP__HOST=gp_dns_pkap1123_audit.gp.df.sbrf.ru
DATABASE__GP__PORT=5432
DATABASE__GP__DATABASE=capgp3
DATABASE__GP__SCHEMA=s_grnplm_ld_audit_da_project_4
DATABASE__GP__TABLE_PREFIX=t_db_oarb_audit_act_

# === Безопасность ===
SECURITY__MAX_REQUEST_SIZE=10485760
SECURITY__RATE_LIMIT_PER_MINUTE=1024
SECURITY__MAX_TRACKED_IPS=100
SECURITY__RATE_LIMIT_TTL=120

# === AI-чат (OpenAI-совместимый API, опционально) ===
# Без этих настроек чат работает в режиме заглушки.
# CHAT__API_BASE=https://api.openai.com/v1
# CHAT__API_KEY=sk-...
# CHAT__MODEL=gpt-4o
# CHAT__TEMPERATURE=0.1
# CHAT__MAX_TOOL_ROUNDS=5
# CHAT__TOOL_EXECUTION_TIMEOUT=30

# === Домен: Акты — Блокировки ===
ACTS__LOCK__DURATION_MINUTES=10
ACTS__LOCK__INACTIVITY_TIMEOUT_MINUTES=5
ACTS__LOCK__INACTIVITY_CHECK_INTERVAL_SECONDS=30
ACTS__LOCK__MIN_EXTENSION_INTERVAL_MINUTES=5
ACTS__LOCK__INACTIVITY_DIALOG_TIMEOUT_SECONDS=15

# === Домен: Акты — Форматирование ===
ACTS__FORMATTING__MAX_IMAGE_SIZE_MB=10.0
ACTS__FORMATTING__DOCX_IMAGE_WIDTH=4.0
ACTS__FORMATTING__DOCX_CAPTION_FONT_SIZE=10
ACTS__FORMATTING__DOCX_MAX_HEADING_LEVEL=9
ACTS__FORMATTING__TEXT_HEADER_WIDTH=80
ACTS__FORMATTING__TEXT_INDENT_SIZE=2
ACTS__FORMATTING__MARKDOWN_MAX_HEADING_LEVEL=6
ACTS__FORMATTING__HTML_PARSE_TIMEOUT=30
ACTS__FORMATTING__MAX_HTML_DEPTH=100
ACTS__FORMATTING__HTML_PARSE_CHUNK_SIZE=1000
ACTS__FORMATTING__MAX_RETRIES=3
ACTS__FORMATTING__RETRY_DELAY=0.5

# === Домен: Акты — Ресурсы ===
ACTS__RESOURCE__MAX_CONCURRENT_FILE_OPERATIONS=100
ACTS__RESOURCE__SAVE_OPERATION_TIMEOUT=300
ACTS__RESOURCE__SAVE_ACT_TIMEOUT=300
ACTS__RESOURCE__MAX_TREE_DEPTH=50

# === Домен: Акты — Фактуры ===
ACTS__INVOICE__HIVE_SCHEMA=team_sva_oarb_3
ACTS__INVOICE__GP_SCHEMA=s_grnplm_ld_audit_da_sandbox_oarb
ACTS__INVOICE__HIVE_REGISTRY_SCHEMA=s_grnplm_ld_audit_da_project_4
ACTS__INVOICE__HIVE_REGISTRY_TABLE=t_db_oarb_ua_hadoop_tables
ACTS__INVOICE__HIVE_REGISTRY_COL_TABLE=table_name
ACTS__INVOICE__METRIC_DICT_TABLE=t_db_oarb_ua_violation_metric_dict
ACTS__INVOICE__PROCESS_DICT_TABLE=t_db_oarb_ua_process_dict
ACTS__INVOICE__PROCESS_DICT_COL_CODE=process_code
ACTS__INVOICE__PROCESS_DICT_COL_NAME=process_name
ACTS__INVOICE__SUBSIDIARY_DICT_TABLE=t_db_oarb_ua_subsidiary_dict
ACTS__INVOICE__SUBSIDIARY_DICT_COL_NAME=name

# === Домен: Акты — Аудит-лог ===
ACTS__AUDIT_LOG__RETENTION_DAYS=365
ACTS__AUDIT_LOG__MAX_CONTENT_VERSIONS=50

# === Домен: Администрирование ===
ADMIN__USER_DIRECTORY__SCHEMA=s_grnplm_ld_audit_da_project_4
ADMIN__USER_DIRECTORY__TABLE=t_db_oarb_ua_user
ADMIN__USER_DIRECTORY__BRANCH_FILTER=Отдел аудита розничного бизнеса
ADMIN__USER_DIRECTORY__DEFAULT_ADMIN=00000000
