# ============================================================
# Audit Workstation — Environment Configuration
# ============================================================
# Скопируйте этот файл как .env и заполните значения.
# Переменные используют __ как разделитель вложенных настроек.
# ============================================================

# ============================================================
# Оглавление
# ============================================================
#  1. Метаданные приложения и Auth                  (строка ~21)
#  2. Сервер и логирование                          (строка ~33)
#  3. База данных (PostgreSQL/Greenplum)            (строка ~40)
#  4. Безопасность и Security headers               (строка ~66)
#  5. Observability (метрики в БД)                  (строка ~85)
#  6. Домен: AI-чат — LLM, retry, оркестрация       (строка ~92)
#  7. Домен: AI-чат — agent_bridge (внешний агент)  (строка ~154)
#  8. Домен: Акты — блокировки и форматирование     (строка ~169)
#  9. Домен: Акты — ресурсы / фактуры / аудит-лог   (строка ~190)
# 10. Домен: Справочники UA                         (строка ~208)
# 11. Домен: ЦК Фин.Рез. и Клиентский опыт          (строка ~223)
# 12. Домен: Администрирование и DB pool monitor    (строка ~232)
# ============================================================

# Метаданные приложения
APP_TITLE=Audit Workstation          # Название, отображаемое в UI
APP_VERSION=1.0.0                    # Версия приложения. Используется как
                                     # cache-bust токен (?v=...) для статики
                                     # в шаблонах. Если оставить дефолт "1.0.0",
                                     # приложение возьмёт короткий git-хеш HEAD.

# Аутентификация (JupyterHub / DataLab)
# В DataLab берётся из переменных окружения автоматически.
JUPYTERHUB_USER=22494524_omega-sbrf-ru   # Логин пользователя JupyterHub

# Внешний сервис генерации уникальных ID для связи актов и фактур (заглушка, не используется).
# При появлении сервиса — раскомментировать и указать URL.
# AUDIT_ID_SERVICE_URL=                # Базовый URL audit-id-сервиса
# AUDIT_ID_SERVICE_TIMEOUT=10          # Таймаут запросов к сервису, сек.

# === Сервер ===
SERVER__HOST=0.0.0.0                 # Адрес привязки сервера
SERVER__PORT=8005                    # Порт сервера
SERVER__API_V1_PREFIX=/api/v1        # Префикс API-роутов
SERVER__LOG_LEVEL=INFO               # Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_FORMAT=text                      # Формат логов: text (для разработки) | json (структурированный для агрегаторов)

# === База данных ===
# Тип: "postgresql" (локальная) или "greenplum" (через Kerberos)
DATABASE__TYPE=greenplum             # Тип СУБД

DATABASE__HOST=localhost             # Хост PostgreSQL
DATABASE__PORT=5432                  # Порт PostgreSQL
DATABASE__NAME=audit_workstation     # Имя базы данных PostgreSQL
DATABASE__USER=postgres              # Пользователь PostgreSQL
DATABASE__PASSWORD=                  # Пароль PostgreSQL

DATABASE__POOL_MIN_SIZE=5            # Минимум соединений в пуле (фон: батчеры + polling-runners)
DATABASE__POOL_MAX_SIZE=20           # Максимум соединений в пуле (потолок при всплесках HTTP)
DATABASE__COMMAND_TIMEOUT=60         # Таймаут SQL-запроса (сек)
DATABASE__ACQUIRE_TIMEOUT=10         # Таймаут ожидания свободного соединения из пула (сек); при исчерпании пула — 503 вместо бессрочного зависания
DATABASE__POOL_WARMUP_ENABLED=true   # Прогрев пула при старте (открыть pool_min_size соединений до первых запросов)

# Префикс всех таблиц приложения (acts, chat, admin). Общий для PG и GP,
# чтобы имена совпадали в обоих окружениях.
DATABASE__TABLE_PREFIX=t_db_oarb_audit_act_

# === Greenplum (только при DATABASE__TYPE=greenplum) ===
# Требует предварительный kinit для Kerberos-аутентификации.
DATABASE__GP__HOST=gp_dns_pkap1123_audit.gp.df.sbrf.ru     # Хост Greenplum
DATABASE__GP__PORT=5432                                    # Порт Greenplum
DATABASE__GP__DATABASE=capgp3                              # Имя базы Greenplum
DATABASE__GP__SCHEMA=s_grnplm_ld_audit_da_project_4        # Основная схема GP (дефолт для всех доменов)

# === Безопасность ===
SECURITY__MAX_REQUEST_SIZE=10485760        # Макс. размер запроса (байт, 10 МБ)
SECURITY__RATE_LIMIT_PER_MINUTE=1024       # Лимит запросов в минуту на IP
SECURITY__MAX_TRACKED_IPS=100              # Макс. кол-во отслеживаемых IP
SECURITY__RATE_LIMIT_TTL=120               # TTL записей rate-limit (сек)
SECURITY__SINGLETON_LOCK_STALE_TTL_SEC=60  # TTL singleton-lock; через сколько секунд старая запись считается «мертвой»

# === Security response headers ===
# CSP пока в report-only — выключить флаг после выноса inline onclick/onchange из Jinja-шаблонов.
SECURITY__CSP_ENABLED=true                  # Выставлять Content-Security-Policy
SECURITY__CSP_REPORT_ONLY=true              # true → Content-Security-Policy-Report-Only (мониторинг без блокировки)
# SECURITY__CSP_POLICY=                     # Полная политика; переопределить только при необходимости
SECURITY__HSTS_ENABLED=true                 # Выставлять Strict-Transport-Security (только для https-ответов)
SECURITY__HSTS_MAX_AGE=31536000             # 1 год
SECURITY__HSTS_INCLUDE_SUBDOMAINS=true
SECURITY__FRAME_OPTIONS=SAMEORIGIN          # DENY | SAMEORIGIN — защита от clickjacking
SECURITY__REFERRER_POLICY=strict-origin-when-cross-origin
# SECURITY__PERMISSIONS_POLICY=             # camera=(), microphone=(), ... по умолчанию всё запрещено

# === Observability (метрики в БД) ===
# Батчинг записи трёх потоков метрик: HTTP-запросы, tool-метрики чата,
# audit-лог чата. Уменьшает кол-во транзакций под нагрузкой.
OBSERVABILITY__METRICS_BATCH_SIZE=100              # Кол-во записей для flush
OBSERVABILITY__METRICS_FLUSH_INTERVAL_SEC=5.0      # Сек, через которое flush даже если пакет не полный
OBSERVABILITY__METRICS_MAX_BUFFER_SIZE=10000       # Защитный потолок (дроп старых при переполнении)

# === Домен: AI-чат ===
# Без API_BASE, API_KEY и MODEL чат работает в режиме заглушки.

# Схема БД для собственных таблиц чата (conversations, messages, files,
# tool_metrics, audit_log). Пусто → основная схема GP / без квалификатора PG.
# Учитывается и при создании таблиц, и при доступе.
# CHAT__SCHEMA_NAME=

# --- Подключение к LLM-провайдеру ---
# API_BASE/API_KEY/MODEL зависят от деплоя — заполнить вручную; готовые примеры по профилям — developer-guide §9.4.1.
CHAT__PROFILE=sglang                                        # sglang | openrouter | openai | gigachat
# CHAT__API_BASE=http://127.0.0.1:30000/v1                  # base URL OpenAI-совместимого API, БЕЗ /chat/completions
# CHAT__API_KEY=local-test-key                              # API-ключ или внутренний токен
# CHAT__MODEL=/home/datalab/nfs/llm/Qwen-8B                 # имя/путь модели
# CHAT__EXTRA_HEADERS={"HTTP-Referer":"..."}                # JSON; OpenRouter принимает HTTP-Referer/X-Title для атрибуции
CHAT__TEMPERATURE=0.1                         # Температура генерации (0–2)
CHAT__STREAMING_ENABLED=true                  # Legacy-флаг стриминга LLM-вызова; клиентский транспорт — POST + polling, токен-стриминга в UI нет (gigachat-proxy стриминг не поддерживает)
CHAT__REQUEST_TIMEOUT=60                      # Таймаут одного HTTP-запроса к LLM (сек)

# --- Retry-политика для transient-ошибок LLM-провайдера ---
# 4xx (кроме 429) НЕ повторяются: это клиентские ошибки.
CHAT__RETRY__ON_429=true                      # повторять при 429 rate-limit
CHAT__RETRY__ON_5XX=true                      # повторять при 5xx
CHAT__RETRY__MAX_ATTEMPTS=5
CHAT__RETRY__BACKOFF_BASE_SEC=2.0
CHAT__RETRY__CONNECT_MAX_ATTEMPTS=2           # Кап попыток для обрывов соединения (сервер лёг): fast-fail на fallback, без 30с ожидания. APITimeoutError сюда НЕ относится

# --- Оркестрация ---
CHAT__SMALLTALK_MODE=local                    # local | forward — отвечать локально или форвардить внешнему агенту
# CHAT__SYSTEM_PROMPT=Ты — AI-ассистент...    # Системный промпт (есть значение по умолчанию в settings.py)
CHAT__MAX_TOOL_ROUNDS=5                       # Макс. итераций вызова инструментов
CHAT__TOOL_EXECUTION_TIMEOUT=30               # Таймаут выполнения инструмента (сек)
CHAT__MAX_HISTORY_LENGTH=50                   # Макс. сообщений истории в контексте LLM
CHAT__MAX_MESSAGE_CONTENT_LENGTH=10000        # Макс. длина сообщения пользователя (символов)
CHAT__HISTORY_FULL_CONTEXT_DEPTH=5            # Кол-во последних сообщений с полным контентом (file/image-блоки); более старые получают placeholder

# --- Per-user rate limit ---
CHAT__RATE_LIMIT_MESSAGES_PER_MINUTE_PER_USER=10  # Лимит сообщений в минуту на пользователя (POST /messages); скользящее окно 60 сек
# CHAT__MAX_PARALLEL_STREAMS_PER_USER=3         # Максимум параллельных запросов к агенту (chat_agent_messages_bus pending/in_progress) на пользователя; при превышении → ошибка

# --- Лимиты буферизации блоков LLM (legacy; защита от self-DoS на гигантских чанках LLM) ---
CHAT__DELTA_CHUNK_FLUSH_BYTES=65536           # Порог буфера delta (байт): по достижении эмитим block_delta; гигантские входящие чанки также режутся на куски этого размера
CHAT__DELTA_BLOCK_MAX_BYTES=5242880           # Общий лимит на один блок (байт, 5 МБ): при превышении блок усекается маркером и закрывается; последующие deltas игнорируются

# --- Fallback LLM-провайдер и circuit breaker ---
# Если primary-провайдер сыпет 5xx/ConnectionError/Timeout — после N подряд ошибок
# circuit breaker размыкается и оркестратор «садится» на fallback (GigaChat). Перепроверка
# primary уходит в фоновую задачу chat.llm_health_probe (см. ниже) — живой запрос пользователя
# больше НЕ становится пробой. Как только primary отвечает, circuit замыкается обратно.
# Если fallback_profile пустой — fallback и health-probe не задействуются.
CHAT__FALLBACK_PROFILE=gigachat                 # Профиль fallback (sglang | openrouter | openai | gigachat); пусто = отключено
CHAT__FALLBACK_API_BASE=                        # base URL fallback-провайдера (GigaChat proxy)
CHAT__FALLBACK_API_KEY=                         # API-ключ fallback-провайдера
CHAT__FALLBACK_MODEL=GigaChat-3-Ultra           # Имя/путь модели fallback
# CHAT__FALLBACK_EXTRA_HEADERS={}                # JSON, доп. заголовки для fallback
CHAT__CIRCUIT_BREAKER_FAILURE_THRESHOLD=2        # Подряд ошибок primary до размыкания circuit (садимся на fallback)
CHAT__CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SEC=60    # Сек до half_open-пробы; при включённом health-probe не используется (восстановление из фона)

# --- Фоновая перепроверка primary-LLM (health-probe) ---
# Пока circuit открыт, фоновая задача пингует primary с adaptive-backoff и закрывает circuit,
# как только primary отвечает. Так пользователь не ждёт ретраи на каждом запросе.
CHAT__HEALTH_PROBE__ENABLED=true                 # Включить фоновую перепроверку primary
CHAT__HEALTH_PROBE__POLL_MIN_INTERVAL_SEC=2.0    # Минимальный интервал пинга primary
CHAT__HEALTH_PROBE__POLL_MAX_INTERVAL_SEC=30.0   # Максимальный интервал (потолок backoff)
CHAT__HEALTH_PROBE__POLL_BACKOFF_MULTIPLIER=1.5  # Множитель роста интервала при недоступном primary
CHAT__HEALTH_PROBE__TIMEOUT_SEC=5.0              # Таймаут одного ping-запроса к primary

# --- Файлы ---
CHAT__MAX_FILE_SIZE=10485760                  # Макс. размер файла (байт, 10 МБ)
# Whitelist MIME-типов (JSON-массив, ТОЧНЫЕ значения; '*' запрещён). Дефолт — developer-guide §9.4.2.
# CHAT__ALLOWED_MIME_TYPES=["text/plain","application/pdf","image/png"]
CHAT__MAX_FILES_PER_MESSAGE=5                 # Макс. файлов в одном сообщении
CHAT__MAX_TOTAL_FILE_SIZE=31457280            # Макс. суммарный размер файлов в сообщении (байт, 30 МБ)

# --- Хранение ---
CHAT__MAX_CONVERSATIONS_PER_USER=100          # Макс. разговоров на пользователя
CHAT__MAX_MESSAGES_PER_CONVERSATION=500       # Макс. сообщений в одном разговоре

# --- Канал к внешнему ИИ-агенту через bus-таблицу chat_agent_messages_bus ---
# Polling-only, без постоянных соединений.
# CHAT__AGENT_CHANNEL__SCHEMA_NAME=                                  # Схема bus-таблицы; пусто → схема чата (CHAT__SCHEMA_NAME) → основная. Для общей integration-схемы с внешним агентом
CHAT__AGENT_CHANNEL__TABLE_NAME=chat_agent_messages_bus                       # Имя bus-таблицы
CHAT__AGENT_CHANNEL__POLL_MIN_INTERVAL_SEC=2.0                       # Минимальный интервал polling (при активности агента)
CHAT__AGENT_CHANNEL__POLL_MAX_INTERVAL_SEC=10.0                      # Максимальный интервал polling (при тишине)
CHAT__AGENT_CHANNEL__POLL_BACKOFF_MULTIPLIER=1.5                     # Множитель роста интервала между пустыми тиками
CHAT__AGENT_CHANNEL__ANSWER_TIMEOUT_SEC=600                          # Максимальное время ожидания ответа агента (сек, 10 минут)
CHAT__AGENT_CHANNEL__MAX_BLOCK_TEXT_SIZE=262144                      # Лимит размера текста блока (UTF-8 байт)

# === Домен: Акты — Блокировки ===
ACTS__LOCK__DURATION_MINUTES=15                      # Длительность блокировки акта (мин)
ACTS__LOCK__INACTIVITY_TIMEOUT_MINUTES=5             # Таймаут бездействия до показа диалога (мин)
ACTS__LOCK__INACTIVITY_CHECK_INTERVAL_SECONDS=30     # Интервал проверки активности (сек)
ACTS__LOCK__MIN_EXTENSION_INTERVAL_MINUTES=5         # Мин. интервал продления блокировки (мин)
ACTS__LOCK__INACTIVITY_DIALOG_TIMEOUT_SECONDS=15     # Таймаут диалога «Продолжить?» (сек)

# === Домен: Акты — Форматирование ===
ACTS__FORMATTING__MAX_IMAGE_SIZE_MB=10.0             # Макс. размер изображения (МБ)
ACTS__FORMATTING__DOCX_IMAGE_WIDTH=4.0               # Ширина изображения в DOCX (дюймы)
ACTS__FORMATTING__DOCX_CAPTION_FONT_SIZE=10          # Размер шрифта подписей в DOCX
ACTS__FORMATTING__DOCX_MAX_HEADING_LEVEL=9           # Макс. уровень заголовков DOCX
ACTS__FORMATTING__TEXT_HEADER_WIDTH=80               # Ширина заголовка в текстовом формате
ACTS__FORMATTING__TEXT_INDENT_SIZE=2                 # Отступ в текстовом формате (пробелы)
ACTS__FORMATTING__MARKDOWN_MAX_HEADING_LEVEL=6       # Макс. уровень заголовков Markdown
ACTS__FORMATTING__HTML_PARSE_TIMEOUT=30              # Таймаут парсинга HTML (сек)
ACTS__FORMATTING__MAX_HTML_DEPTH=100                 # Макс. глубина вложенности HTML
ACTS__FORMATTING__HTML_PARSE_CHUNK_SIZE=1000         # Размер чанка парсинга HTML
ACTS__FORMATTING__MAX_RETRIES=3                      # Макс. попыток при ошибке
ACTS__FORMATTING__RETRY_DELAY=0.5                    # Задержка между попытками (сек)

# === Домен: Акты — Ресурсы ===
ACTS__RESOURCE__MAX_CONCURRENT_FILE_OPERATIONS=100    # Макс. параллельных файловых операций
ACTS__RESOURCE__SAVE_OPERATION_TIMEOUT=300            # Таймаут операции сохранения (сек)
ACTS__RESOURCE__SAVE_ACT_TIMEOUT=300                  # Таймаут сохранения акта (сек)
ACTS__RESOURCE__MAX_TREE_DEPTH=50                     # Макс. глубина дерева акта

# === Домен: Акты — Фактуры ===
ACTS__INVOICE__HIVE_SCHEMA=team_sva_oarb_3                          # Схема Hive
ACTS__INVOICE__GP_SCHEMA=s_grnplm_ld_audit_da_sandbox_oarb          # Схема GP для списка таблиц
ACTS__INVOICE__HIVE_REGISTRY_SCHEMA=s_grnplm_ld_audit_da_project_4  # Схема реестра Hive-таблиц
ACTS__INVOICE__HIVE_REGISTRY_TABLE=t_db_oarb_ua_hadoop_tables       # Таблица реестра Hive

# === Домен: Акты — Аудит-лог ===
ACTS__AUDIT_LOG__RETENTION_DAYS=365              # Срок хранения записей (дней)
ACTS__AUDIT_LOG__MAX_CONTENT_VERSIONS=50         # Макс. версий содержимого акта
ACTS__AUDIT_LOG__MAX_DIFF_ELEMENTS=20            # Макс. элементов в diff
ACTS__AUDIT_LOG__MAX_DIFF_CELLS_PER_TABLE=50     # Макс. ячеек diff на таблицу

# === Домен: Справочники UA ===
# Имена справочных таблиц UA. Используются доменами ua_data и acts (фактуры).
# UA_DATA__SCHEMA_NAME=               # Схема справочников (пустая — основная схема GP)
UA_DATA__PROCESS_DICT=t_db_oarb_ua_process_dict                    # Справочник процессов
UA_DATA__TERBANK_DICT=t_db_oarb_ua_terbank_dict                    # Справочник территориальных банков
UA_DATA__VIOLATION_METRIC_DICT=t_db_oarb_ua_violation_metric_dict  # Справочник метрик нарушений
UA_DATA__DEPARTMENTS=t_db_oarb_ua_departments                      # Справочник подразделений
UA_DATA__GOSB_DICT=t_db_oarb_ua_gosb_dict                          # Справочник ГОСБов
UA_DATA__VSP_DICT=t_db_oarb_ua_vsp_dict                            # Справочник ВСП
UA_DATA__CHANNEL_DICT=t_db_oarb_ua_channel_dict                    # Справочник каналов
UA_DATA__PRODUCT_DICT=t_db_oarb_ua_product_dict                    # Справочник продуктов
UA_DATA__TEAM_DICT=t_db_oarb_ua_team_dict                          # Справочник команд аудита
UA_DATA__SUBSIDIARY_DICT=t_db_oarb_ua_subsidiary_dict              # Справочник дочерних организаций
UA_DATA__VIOLATION_RISK_TYPE_DICT=t_db_oarb_ua_violation_risk_type_dict  # Справочник типов риска (ЦК Фин.Рез.)

# === Домен: ЦК Фин.Рез. ===
# CK_FIN_RES__SCHEMA_NAME=            # Схема таблиц ЦК Фин.Рез. (пустая — основная схема GP)
CK_FIN_RES__FR_VALIDATION_TABLE=t_db_oarb_ck_fr_validation         # Таблица валидации фин. результатов
CK_FIN_RES__FR_VALIDATION_VIEW=v_db_oarb_ck_fr_validation          # Представление валидации фин. результатов

# === Домен: ЦК Клиентский опыт ===
# CK_CLIENT_EXP__SCHEMA_NAME=         # Схема таблиц ЦК Клиентский опыт (пустая — основная схема GP)
CK_CLIENT_EXP__CS_VALIDATION_TABLE=t_db_oarb_ck_cs_validation      # Таблица валидации клиентского опыта
CK_CLIENT_EXP__CS_VALIDATION_VIEW=v_db_oarb_ck_cs_validation       # Представление валидации клиентского опыта

# === Домен: Администрирование ===
# ADMIN__USER_DIRECTORY__SCHEMA=       # Схема справочника пользователей (пустая — основная схема GP)
ADMIN__USER_DIRECTORY__TABLE=t_db_oarb_ua_user                        # Таблица справочника пользователей
ADMIN__USER_DIRECTORY__BRANCH_FILTER=Отдел аудита розничного бизнеса  # Фильтр подразделения для начального заполнения ролей
ADMIN__USER_DIRECTORY__DEFAULT_ADMIN=22494524                         # Табельный номер администратора по умолчанию
ADMIN__HTTP_METRICS_ENABLED=false                                     # Включить запись HTTP-метрик в БД

# Мониторинг asyncpg-пула — WARNING-лог при acquired >= warn_ratio × POOL_MAX_SIZE.
# Без БД-таблицы (агрегируется внешней системой логирования).
ADMIN__DB_POOL_MONITOR__ENABLED=true                                  # Запускать фоновый мониторинг пула
ADMIN__DB_POOL_MONITOR__CHECK_INTERVAL_SEC=30.0                       # Интервал между замерами (сек)
ADMIN__DB_POOL_MONITOR__WARN_RATIO=0.9                                # Порог WARNING'а (0.9 = алёрт при 18/20)

# === Домен: Центр уведомлений ===
NOTIFICATIONS__LIST_LIMIT=50                                          # Лимит уведомлений в списке по умолчанию
NOTIFICATIONS__RETENTION_DAYS=90                                      # Срок хранения уведомлений (дней; для опц. фоновой очистки)
