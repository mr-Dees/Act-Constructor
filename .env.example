# ============================================================
# Audit Workstation — пример конфигурации
# Скопируйте в .env и заполните значения. Разделитель вложенных настроек — __.
# ============================================================

# === Приложение и аутентификация ===
APP_TITLE=Audit Workstation
APP_VERSION=1.0.0                        # дефолт "1.0.0" → берётся короткий git-хеш HEAD (cache-bust статики)
JUPYTERHUB_USER=22494524_omega-sbrf-ru   # в DataLab подставляется автоматически

# Внешний сервис генерации ID для связи актов и фактур (заглушка, пока не используется).
# AUDIT_ID_SERVICE_URL=
# AUDIT_ID_SERVICE_TIMEOUT=10

# === Сервер ===
SERVER__HOST=0.0.0.0
SERVER__PORT=8000                    # должен отличаться от SQLAGENT__SIDECAR_PORT
SERVER__API_V1_PREFIX=/api/v1
SERVER__LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                      # text | json

# === База данных ===
DATABASE__TYPE=greenplum             # postgresql | greenplum
DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__NAME=audit_workstation
DATABASE__USER=postgres
DATABASE__PASSWORD=
DATABASE__POOL_MIN_SIZE=5
DATABASE__POOL_MAX_SIZE=20
DATABASE__COMMAND_TIMEOUT=60
DATABASE__ACQUIRE_TIMEOUT=10         # при исчерпании пула → 503 вместо зависания
DATABASE__POOL_WARMUP_ENABLED=true
# Общий префикс всех таблиц приложения (PG и GP).
DATABASE__TABLE_PREFIX=t_db_oarb_audit_act_

# === Greenplum (при DATABASE__TYPE=greenplum; требует kinit) ===
DATABASE__GP__HOST=gp_dns_pkap1123_audit.gp.df.sbrf.ru
DATABASE__GP__PORT=5432
DATABASE__GP__DATABASE=capgp3
DATABASE__GP__SCHEMA=s_grnplm_ld_audit_da_project_4   # основная схема (дефолт для всех доменов)

# === Безопасность ===
SECURITY__MAX_REQUEST_SIZE=10485760        # 10 МБ
SECURITY__RATE_LIMIT_PER_MINUTE=1024
SECURITY__MAX_TRACKED_IPS=100
SECURITY__RATE_LIMIT_TTL=120
SECURITY__SINGLETON_LOCK_STALE_TTL_SEC=60

# === Security-заголовки ===
# CSP enforce: script-src защищён per-request nonce; style-src сохраняет 'unsafe-inline'.
SECURITY__CSP_ENABLED=true
SECURITY__CSP_REPORT_ONLY=false            # true → только мониторинг, без блокировки
# SECURITY__CSP_POLICY=                     # своя политика; плейсхолдер {nonce} в script-src обязателен
SECURITY__HSTS_ENABLED=true                # только для https-ответов
SECURITY__HSTS_MAX_AGE=31536000            # 1 год
SECURITY__HSTS_INCLUDE_SUBDOMAINS=true
SECURITY__FRAME_OPTIONS=SAMEORIGIN         # DENY | SAMEORIGIN
SECURITY__REFERRER_POLICY=strict-origin-when-cross-origin
# SECURITY__PERMISSIONS_POLICY=            # по умолчанию всё запрещено

# === Observability (метрики в БД) ===
OBSERVABILITY__METRICS_BATCH_SIZE=100
OBSERVABILITY__METRICS_FLUSH_INTERVAL_SEC=5.0
OBSERVABILITY__METRICS_MAX_BUFFER_SIZE=10000

# === Домен: AI-чат ===
# Без API_BASE/API_KEY/MODEL чат работает в режиме заглушки.
# CHAT__SCHEMA_NAME=                        # схема таблиц чата; пусто → основная схема GP

# --- LLM-провайдер (примеры по профилям — developer-guide §9.4.1) ---
# Секрет можно не хранить в файле: CHAT__API_KEY=${JPY_API_TOKEN} (интерполяция ${VAR} включена).
CHAT__PROFILE=sglang                        # sglang | openrouter | openai | gigachat
# CHAT__API_BASE=http://127.0.0.1:30000/v1  # base URL, БЕЗ /chat/completions
# CHAT__API_KEY=local-test-key
# CHAT__MODEL=/home/datalab/nfs/llm/Qwen-8B
# CHAT__EXTRA_HEADERS={"HTTP-Referer":"..."} # JSON; OpenRouter — атрибуция
CHAT__TEMPERATURE=0.1
CHAT__REQUEST_TIMEOUT=60

# --- Retry для transient-ошибок LLM (4xx кроме 429 не повторяются) ---
CHAT__RETRY__ON_429=true
CHAT__RETRY__ON_5XX=true
CHAT__RETRY__MAX_ATTEMPTS=5
CHAT__RETRY__BACKOFF_BASE_SEC=2.0
CHAT__RETRY__CONNECT_MAX_ATTEMPTS=2         # кап для обрывов соединения (fast-fail на fallback)

# --- Оркестрация ---
CHAT__SMALLTALK_MODE=local                  # local | forward
# CHAT__SYSTEM_PROMPT=...                    # есть дефолт в settings.py
CHAT__MAX_TOOL_ROUNDS=5
CHAT__TOOL_EXECUTION_TIMEOUT=30
CHAT__MAX_HISTORY_LENGTH=50
CHAT__MAX_MESSAGE_CONTENT_LENGTH=10000
CHAT__HISTORY_FULL_CONTEXT_DEPTH=5          # последних сообщений с полным контентом; старее → placeholder

# --- Лимиты на пользователя ---
CHAT__RATE_LIMIT_MESSAGES_PER_MINUTE_PER_USER=10
# CHAT__MAX_PARALLEL_STREAMS_PER_USER=3      # макс. параллельных запросов к агенту

# --- Fallback-провайдер + circuit breaker + health-probe ---
# Если primary сыпет 5xx/timeout — после N ошибок circuit размыкается и оркестратор
# садится на fallback; перепроверка primary уходит в фоновую health-probe. Пусто = выключено.
CHAT__FALLBACK_PROFILE=gigachat
CHAT__FALLBACK_API_BASE=
CHAT__FALLBACK_API_KEY=
CHAT__FALLBACK_MODEL=GigaChat-3-Ultra
# CHAT__FALLBACK_EXTRA_HEADERS={}
CHAT__CIRCUIT_BREAKER_FAILURE_THRESHOLD=2
CHAT__CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SEC=60   # при включённом health-probe не используется
CHAT__HEALTH_PROBE__ENABLED=true
CHAT__HEALTH_PROBE__POLL_MIN_INTERVAL_SEC=2.0
CHAT__HEALTH_PROBE__POLL_MAX_INTERVAL_SEC=30.0
CHAT__HEALTH_PROBE__POLL_BACKOFF_MULTIPLIER=1.5
CHAT__HEALTH_PROBE__TIMEOUT_SEC=5.0

# --- Файлы ---
CHAT__MAX_FILE_SIZE=10485760                # 10 МБ
# CHAT__ALLOWED_MIME_TYPES=["text/plain","application/pdf","image/png"]  # дефолт — developer-guide §9.4.2
CHAT__MAX_FILES_PER_MESSAGE=5
CHAT__MAX_TOTAL_FILE_SIZE=31457280          # 30 МБ

# --- Хранение ---
CHAT__MAX_CONVERSATIONS_PER_USER=100
CHAT__MAX_MESSAGES_PER_CONVERSATION=500

# --- Канал к внешнему ИИ-агенту (bus-таблица, polling-only) ---
# CHAT__AGENT_CHANNEL__SCHEMA_NAME=          # схема шины; пусто → схема чата → основная
# Имя bus-таблицы — целиком, БЕЗ app-префикса (DATABASE__TABLE_PREFIX к шине не клеится).
CHAT__AGENT_CHANNEL__TABLE_NAME=t_db_oarb_audit_act_chat_agent_messages_bus
CHAT__AGENT_CHANNEL__POLL_MIN_INTERVAL_SEC=2.0
CHAT__AGENT_CHANNEL__POLL_MAX_INTERVAL_SEC=10.0
CHAT__AGENT_CHANNEL__POLL_BACKOFF_MULTIPLIER=1.5
CHAT__AGENT_CHANNEL__ANSWER_TIMEOUT_SEC=600     # 10 минут
CHAT__AGENT_CHANNEL__CLAIM_TIMEOUT_SEC=1800     # 30 минут
CHAT__AGENT_CHANNEL__MAX_BLOCK_TEXT_SIZE=262144

# === Домен: Акты — блокировки ===
ACTS__LOCK__DURATION_MINUTES=15
ACTS__LOCK__INACTIVITY_TIMEOUT_MINUTES=5
ACTS__LOCK__INACTIVITY_CHECK_INTERVAL_SECONDS=30
ACTS__LOCK__MIN_EXTENSION_INTERVAL_MINUTES=5
ACTS__LOCK__INACTIVITY_DIALOG_TIMEOUT_SECONDS=15

# === Домен: Акты — форматирование ===
ACTS__FORMATTING__MAX_IMAGE_SIZE_MB=10.0
ACTS__FORMATTING__DOCX_IMAGE_WIDTH=4.0      # дюймы
ACTS__FORMATTING__DOCX_CAPTION_FONT_SIZE=10
ACTS__FORMATTING__DOCX_MAX_HEADING_LEVEL=9
ACTS__FORMATTING__TEXT_HEADER_WIDTH=80
ACTS__FORMATTING__TEXT_INDENT_SIZE=2
ACTS__FORMATTING__MARKDOWN_MAX_HEADING_LEVEL=6
ACTS__FORMATTING__HTML_PARSE_TIMEOUT=30
ACTS__FORMATTING__MAX_HTML_DEPTH=100
ACTS__FORMATTING__HTML_PARSE_CHUNK_SIZE=1000
ACTS__FORMATTING__MAX_RETRIES=3
ACTS__FORMATTING__RETRY_DELAY=0.5

# === Домен: Акты — ресурсы ===
ACTS__RESOURCE__MAX_CONCURRENT_FILE_OPERATIONS=100
ACTS__RESOURCE__SAVE_OPERATION_TIMEOUT=300
ACTS__RESOURCE__SAVE_ACT_TIMEOUT=300
ACTS__RESOURCE__MAX_TREE_DEPTH=50

# === Домен: Акты — фактуры ===
ACTS__INVOICE__HIVE_SCHEMA=team_sva_oarb_3
ACTS__INVOICE__GP_SCHEMA=s_grnplm_ld_audit_da_sandbox_oarb
ACTS__INVOICE__HIVE_REGISTRY_SCHEMA=s_grnplm_ld_audit_da_project_4
ACTS__INVOICE__HIVE_REGISTRY_TABLE=t_db_oarb_ua_hadoop_tables

# === Домен: Акты — аудит-лог ===
ACTS__AUDIT_LOG__RETENTION_DAYS=365
ACTS__AUDIT_LOG__MAX_CONTENT_VERSIONS=50
ACTS__AUDIT_LOG__MAX_DIFF_ELEMENTS=20
ACTS__AUDIT_LOG__MAX_DIFF_CELLS_PER_TABLE=50

# === Домен: Акты — картинки нарушений (inline data-URL) ===
ACTS__IMAGES__MAX_FILE_SIZE=10485760        # 10 МБ
ACTS__IMAGES__MAX_TOTAL_SIZE_PER_ACT=31457280   # 30 МБ
# ACTS__IMAGES__ALLOWED_MIME_TYPES=["image/jpeg","image/png","image/gif"]  # SVG/webp запрещены
ACTS__IMAGES__MAX_ITEMS_PER_VIOLATION=50
ACTS__IMAGES__PREVIEW_MAX_HEIGHT_PERCENT=40     # % высоты листа

# === Домен: Акты — таблицы ===
ACTS__TABLES__MAX_ROWS=64
ACTS__TABLES__MAX_COLS=16
ACTS__TABLES__MIN_COL_WIDTH_PX=80

# === Домен: Акты — текстблоки ===
ACTS__TEXTBLOCKS__FONT_SIZE_MIN=8
ACTS__TEXTBLOCKS__FONT_SIZE_MAX=72
ACTS__TEXTBLOCKS__PER_NODE=10               # макс. число текстблоков на узел дерева

# === Домен: Акты — HTML-санитайзер (единый allowlist для bleach и DOMPurify) ===
# Списки в .env задаются JSON-массивом; по умолчанию берутся из SanitizerSettings.
# ACTS__SANITIZER__ALLOWED_TAGS=["p","br","b","strong","i","em","u","s","strike","del","span","a","ul","ol","li","h1","h2","h3","h4","h5","h6","div"]
# ACTS__SANITIZER__ALLOWED_CSS_PROPERTIES=["font-size","color","background-color","font-weight","font-style","text-decoration","text-decoration-line"]
# ACTS__SANITIZER__ALLOWED_DATA_ATTRS=["data-footnote-id","data-footnote-text","data-link-id","data-link-url"]

# === Домен: Справочники UA (имена таблиц; схема — основная GP) ===
# UA_DATA__SCHEMA_NAME=
UA_DATA__PROCESS_DICT=t_db_oarb_ua_process_dict
UA_DATA__TERBANK_DICT=t_db_oarb_ua_terbank_dict
UA_DATA__VIOLATION_METRIC_DICT=t_db_oarb_ua_violation_metric_dict
UA_DATA__DEPARTMENTS=t_db_oarb_ua_departments
UA_DATA__GOSB_DICT=t_db_oarb_ua_gosb_dict
UA_DATA__VSP_DICT=t_db_oarb_ua_vsp_dict
UA_DATA__CHANNEL_DICT=t_db_oarb_ua_channel_dict
UA_DATA__PRODUCT_DICT=t_db_oarb_ua_product_dict
UA_DATA__TEAM_DICT=t_db_oarb_ua_team_dict
UA_DATA__SUBSIDIARY_DICT=t_db_oarb_ua_subsidiary_dict
UA_DATA__VIOLATION_RISK_TYPE_DICT=t_db_oarb_ua_violation_risk_type_dict

# === Домен: ЦК Фин.Рез. (схема — основная GP) ===
# CK_FIN_RES__SCHEMA_NAME=
CK_FIN_RES__FR_VALIDATION_TABLE=t_db_oarb_ck_fr_validation
CK_FIN_RES__FR_VALIDATION_VIEW=v_db_oarb_ck_fr_validation

# === Домен: ЦК Клиентский опыт (схема — основная GP) ===
# CK_CLIENT_EXP__SCHEMA_NAME=
CK_CLIENT_EXP__CS_VALIDATION_TABLE=t_db_oarb_ck_cs_validation
CK_CLIENT_EXP__CS_VALIDATION_VIEW=v_db_oarb_ck_cs_validation

# === Домен: Администрирование ===
# ADMIN__USER_DIRECTORY__SCHEMA=
ADMIN__USER_DIRECTORY__TABLE=t_db_oarb_ua_user
ADMIN__USER_DIRECTORY__BRANCH_FILTER=Отдел аудита розничного бизнеса   # фильтр для начального заполнения ролей
ADMIN__USER_DIRECTORY__DEFAULT_ADMIN=22494524                          # табельный номер админа по умолчанию
ADMIN__HTTP_METRICS_ENABLED=false

# Мониторинг asyncpg-пула: WARNING при acquired >= warn_ratio × POOL_MAX_SIZE.
ADMIN__DB_POOL_MONITOR__ENABLED=true
ADMIN__DB_POOL_MONITOR__CHECK_INTERVAL_SEC=30.0
ADMIN__DB_POOL_MONITOR__WARN_RATIO=0.9          # 0.9 = алёрт при 18/20

# === Домен: Центр уведомлений ===
NOTIFICATIONS__LIST_LIMIT=50
NOTIFICATIONS__RETENTION_DAYS=90                # для опц. фоновой очистки
NOTIFICATIONS__POLL_INTERVAL_SECONDS=30         # частота опроса фронтом по таймеру

# === Домен: SQL-агент (Text-to-SQL) ===
# Отдельный uvicorn-процесс; AW встраивает его UI через iframe на проксированный порт.
SQLAGENT__ENABLED=true
SQLAGENT__SIDECAR_PORT=8005
