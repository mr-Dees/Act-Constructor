# ============================================================
# Audit Workstation — Environment Configuration
# ============================================================
# Скопируйте этот файл как .env и заполните значения.
# Переменные используют __ как разделитель вложенных настроек.
# ============================================================

# Метаданные приложения
APP_TITLE=Audit Workstation          # Название, отображаемое в UI
APP_VERSION=1.0.0                    # Версия приложения

# Аутентификация (JupyterHub / DataLab)
# В DataLab берётся из переменных окружения автоматически.
JUPYTERHUB_USER=22494524_omega-sbrf-ru   # Логин пользователя JupyterHub

# === Сервер ===
SERVER__HOST=0.0.0.0                 # Адрес привязки сервера
SERVER__PORT=8005                    # Порт сервера
SERVER__API_V1_PREFIX=/api/v1        # Префикс API-роутов
SERVER__LOG_LEVEL=INFO               # Уровень логирования (DEBUG, INFO, WARNING, ERROR)

# === База данных ===
# Тип: "postgresql" (локальная) или "greenplum" (через Kerberos)
DATABASE__TYPE=greenplum             # Тип СУБД

DATABASE__HOST=localhost             # Хост PostgreSQL
DATABASE__PORT=5432                  # Порт PostgreSQL
DATABASE__NAME=audit_workstation     # Имя базы данных PostgreSQL
DATABASE__USER=postgres              # Пользователь PostgreSQL
DATABASE__PASSWORD=                  # Пароль PostgreSQL

DATABASE__POOL_MIN_SIZE=2            # Минимум соединений в пуле
DATABASE__POOL_MAX_SIZE=10           # Максимум соединений в пуле
DATABASE__COMMAND_TIMEOUT=60         # Таймаут SQL-запроса (сек)

# === Greenplum (только при DATABASE__TYPE=greenplum) ===
# Требует предварительный kinit для Kerberos-аутентификации.
DATABASE__GP__HOST=gp_dns_pkap1123_audit.gp.df.sbrf.ru     # Хост Greenplum
DATABASE__GP__PORT=5432                                    # Порт Greenplum
DATABASE__GP__DATABASE=capgp3                              # Имя базы Greenplum
DATABASE__GP__SCHEMA=s_grnplm_ld_audit_da_project_4        # Основная схема GP (дефолт для всех доменов)
DATABASE__GP__TABLE_PREFIX=t_db_oarb_audit_act_            # Префикс таблиц домена актов

# === Безопасность ===
SECURITY__MAX_REQUEST_SIZE=10485760        # Макс. размер запроса (байт, 10 МБ)
SECURITY__RATE_LIMIT_PER_MINUTE=1024       # Лимит запросов в минуту на IP
SECURITY__MAX_TRACKED_IPS=100              # Макс. кол-во отслеживаемых IP
SECURITY__RATE_LIMIT_TTL=120               # TTL записей rate-limit (сек)

# === AI-чат (OpenAI-совместимый API, опционально) ===
# Без этих настроек чат работает в режиме заглушки.
# CHAT__API_BASE=https://api.openai.com/v1    # URL API
# CHAT__API_KEY=sk-...                        # Ключ API
# CHAT__MODEL=gpt-4o                          # Модель
# CHAT__TEMPERATURE=0.1                       # Температура генерации
# CHAT__MAX_TOOL_ROUNDS=5                     # Макс. итераций вызова инструментов
# CHAT__TOOL_EXECUTION_TIMEOUT=30             # Таймаут выполнения инструмента (сек)

# === Домен: Акты — Блокировки ===
ACTS__LOCK__DURATION_MINUTES=10                      # Длительность блокировки акта (мин)
ACTS__LOCK__INACTIVITY_TIMEOUT_MINUTES=5             # Таймаут бездействия до показа диалога (мин)
ACTS__LOCK__INACTIVITY_CHECK_INTERVAL_SECONDS=30     # Интервал проверки активности (сек)
ACTS__LOCK__MIN_EXTENSION_INTERVAL_MINUTES=5         # Мин. интервал продления блокировки (мин)
ACTS__LOCK__INACTIVITY_DIALOG_TIMEOUT_SECONDS=15     # Таймаут диалога «Продолжить?» (сек)

# === Домен: Акты — Форматирование ===
ACTS__FORMATTING__MAX_IMAGE_SIZE_MB=10.0             # Макс. размер изображения (МБ)
ACTS__FORMATTING__DOCX_IMAGE_WIDTH=4.0               # Ширина изображения в DOCX (дюймы)
ACTS__FORMATTING__DOCX_CAPTION_FONT_SIZE=10          # Размер шрифта подписей в DOCX
ACTS__FORMATTING__DOCX_MAX_HEADING_LEVEL=9           # Макс. уровень заголовков DOCX
ACTS__FORMATTING__TEXT_HEADER_WIDTH=80               # Ширина заголовка в текстовом формате
ACTS__FORMATTING__TEXT_INDENT_SIZE=2                 # Отступ в текстовом формате (пробелы)
ACTS__FORMATTING__MARKDOWN_MAX_HEADING_LEVEL=6       # Макс. уровень заголовков Markdown
ACTS__FORMATTING__HTML_PARSE_TIMEOUT=30              # Таймаут парсинга HTML (сек)
ACTS__FORMATTING__MAX_HTML_DEPTH=100                 # Макс. глубина вложенности HTML
ACTS__FORMATTING__HTML_PARSE_CHUNK_SIZE=1000         # Размер чанка парсинга HTML
ACTS__FORMATTING__MAX_RETRIES=3                      # Макс. попыток при ошибке
ACTS__FORMATTING__RETRY_DELAY=0.5                    # Задержка между попытками (сек)

# === Домен: Акты — Ресурсы ===
ACTS__RESOURCE__MAX_CONCURRENT_FILE_OPERATIONS=100    # Макс. параллельных файловых операций
ACTS__RESOURCE__SAVE_OPERATION_TIMEOUT=300            # Таймаут операции сохранения (сек)
ACTS__RESOURCE__SAVE_ACT_TIMEOUT=300                  # Таймаут сохранения акта (сек)
ACTS__RESOURCE__MAX_TREE_DEPTH=50                     # Макс. глубина дерева акта

# === Домен: Акты — Фактуры ===
ACTS__INVOICE__HIVE_SCHEMA=team_sva_oarb_3                          # Схема Hive
ACTS__INVOICE__GP_SCHEMA=s_grnplm_ld_audit_da_sandbox_oarb          # Схема GP для списка таблиц
ACTS__INVOICE__HIVE_REGISTRY_SCHEMA=s_grnplm_ld_audit_da_project_4  # Схема реестра Hive-таблиц
ACTS__INVOICE__HIVE_REGISTRY_TABLE=t_db_oarb_ua_hadoop_tables       # Таблица реестра Hive

# === Домен: Акты — Аудит-лог ===
ACTS__AUDIT_LOG__RETENTION_DAYS=365              # Срок хранения записей (дней)
ACTS__AUDIT_LOG__MAX_CONTENT_VERSIONS=50         # Макс. версий содержимого акта

# === Домен: Справочники UA ===
# Имена справочных таблиц UA. Используются доменами ua_data и acts (фактуры).
# UA_DATA__SCHEMA_NAME=               # Схема справочников (пустая — основная схема GP)
UA_DATA__PROCESS_DICT=t_db_oarb_ua_process_dict                    # Справочник процессов
UA_DATA__TERBANK_DICT=t_db_oarb_ua_terbank_dict                    # Справочник территориальных банков
UA_DATA__VIOLATION_METRIC_DICT=t_db_oarb_ua_violation_metric_dict  # Справочник метрик нарушений
UA_DATA__DEPARTMENTS=t_db_oarb_ua_departments                      # Справочник подразделений
UA_DATA__GOSB_DICT=t_db_oarb_ua_gosb_dict                          # Справочник ГОСБов
UA_DATA__VSP_DICT=t_db_oarb_ua_vsp_dict                            # Справочник ВСП
UA_DATA__CHANNEL_DICT=t_db_oarb_ua_channel_dict                    # Справочник каналов
UA_DATA__PRODUCT_DICT=t_db_oarb_ua_product_dict                    # Справочник продуктов
UA_DATA__TEAM_DICT=t_db_oarb_ua_team_dict                          # Справочник команд аудита
UA_DATA__SUBSIDIARY_DICT=t_db_oarb_ua_subsidiary_dict              # Справочник дочерних организаций

# === Домен: ЦК Фин.Рез. ===
# CK_FIN_RES__SCHEMA_NAME=            # Схема таблиц ЦК Фин.Рез. (пустая — основная схема GP)
CK_FIN_RES__FR_VALIDATION_TABLE=t_db_oarb_ck_fr_validation         # Таблица валидации фин. результатов
CK_FIN_RES__FR_VALIDATION_VIEW=v_db_oarb_ck_fr_validation          # Представление валидации фин. результатов

# === Домен: ЦК Клиентский опыт ===
# CK_CLIENT_EXP__SCHEMA_NAME=         # Схема таблиц ЦК Клиентский опыт (пустая — основная схема GP)
CK_CLIENT_EXP__CS_VALIDATION_TABLE=t_db_oarb_ck_cs_validation      # Таблица валидации клиентского опыта
CK_CLIENT_EXP__CS_VALIDATION_VIEW=v_db_oarb_ck_cs_validation       # Представление валидации клиентского опыта

# === Домен: Администрирование ===
# ADMIN__USER_DIRECTORY__SCHEMA=       # Схема справочника пользователей (пустая — основная схема GP)
ADMIN__USER_DIRECTORY__TABLE=t_db_oarb_ua_user                        # Таблица справочника пользователей
ADMIN__USER_DIRECTORY__BRANCH_FILTER=Отдел аудита розничного бизнеса  # Фильтр подразделения для начального заполнения ролей
ADMIN__USER_DIRECTORY__DEFAULT_ADMIN=22494524                         # Табельный номер администратора по умолчанию
